# ===========================================================================
# VECTOR — root environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values for your setup.
#   cp .env.example .env
# The `.env` file is git-ignored and must never be committed.
# ===========================================================================

# ---- General ------------------------------------------------------------
# development | production
VECTOR_ENV=development
# debug | info | warning | error
VECTOR_LOG_LEVEL=info

# ---- AI Server ----------------------------------------------------------
VECTOR_SERVER_HOST=0.0.0.0
VECTOR_SERVER_PORT=8000
# Comma-separated list of allowed CORS origins for the API.
VECTOR_CORS_ORIGINS=http://localhost:3000

# ---- Language model -----------------------------------------------------
# Which reasoning backend the agent should use: anthropic | openai | local | mock
# `mock` needs no API key and is the default so the stack runs out of the box.
VECTOR_LLM_PROVIDER=mock
VECTOR_LLM_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Memory / persistence ----------------------------------------------
# sqlite | postgres
VECTOR_MEMORY_BACKEND=sqlite
VECTOR_DB_URL=sqlite:///./data/vector.db

# ---- MQTT message bus ---------------------------------------------------
# The MQTT broker is the nervous system that connects the server, robots,
# vision, voice and smart-home devices. See docs/mqtt-topics.md.
VECTOR_MQTT_HOST=localhost
VECTOR_MQTT_PORT=1883
VECTOR_MQTT_USERNAME=
VECTOR_MQTT_PASSWORD=
VECTOR_MQTT_BASE_TOPIC=vector

# ---- Voice assistant ----------------------------------------------------
VECTOR_WAKE_WORD=vector
# Endpoint the voice client uses to reach the server.
VECTOR_SERVER_URL=http://localhost:8000

# ---- Vision -------------------------------------------------------------
# Camera device index or RTSP/HTTP stream URL.
VECTOR_CAMERA_SOURCE=0
VECTOR_VISION_MODEL=yolov8n.pt
