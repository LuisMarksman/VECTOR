# ---------------------------------------------------------------------------
# VECTOR — monorepo .gitignore
# ---------------------------------------------------------------------------

# Environment / secrets
.env
.env.*
!.env.example
*.local
secrets/
credentials.json

# ---- Python -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
.installed.cfg
pip-wheel-metadata/
.Python
.venv/
venv/
env/
ENV/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---- Node / web ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
.turbo/

# ---- C / C++ / Embedded (ESP-IDF, Arduino, PlatformIO) ------------------
*.o
*.a
*.elf
*.bin
*.map
*.hex
.pio/
.pioenvs/
.piolibdeps/
sdkconfig
sdkconfig.old
managed_components/
firmware/**/build/

# ---- ROS2 ---------------------------------------------------------------
robotics/**/build/
robotics/**/install/
robotics/**/log/
*.bag
*.db3

# ---- Machine learning / vision -----------------------------------------
*.pt
*.pth
*.onnx
*.engine
*.weights
*.tflite
models/weights/
datasets/
*.mp4
*.avi

# ---- Data / runtime -----------------------------------------------------
data/
*.db
*.sqlite
*.sqlite3
logs/
*.log

# ---- Editors / OS -------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
.DS_Store
Thumbs.db
